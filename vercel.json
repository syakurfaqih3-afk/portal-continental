{
  "buildCommand": "echo 'Building...'",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server.js" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/server.js" },
    { "src": "/(.*)", "dest": "/public/$1" },
    { "src": "/$", "dest": "/public/index.html" }
  ]
}